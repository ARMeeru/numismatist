// Prisma schema for the Numismatist.app data model.
//
// Source of truth: PRD §11 (Data Model) and §36 (Pre-Build Decisions). Enum
// values are kept in sync by hand with packages/contracts (Zod schemas don't
// generate Prisma enums, and vice versa) — when one changes, change both.
//
// Auth (User, Session, Account, Verification) follows Better Auth's canonical
// Prisma adapter shape (verified via `@better-auth/cli generate`), not a
// hand-rolled one. Notably: password + OAuth credentials live on `Account`
// (one User can have multiple linked Accounts, one per auth method), not on
// `User` directly, and `Verification` is a generic token store Better Auth
// manages itself for both email verification and password reset — this
// replaces the EmailVerificationToken/PasswordResetToken tables originally
// sketched in PRD §36.1. Field names `name`/`image`/`emailVerified` are Better
// Auth's canonical names for what the PRD calls "display name"/"profile
// image"/"email verified"(§11.1) — same fields, renamed to avoid fighting the
// library's field-mapping. `lastLoginAt` was dropped: no feature reads it, and
// Session.createdAt already proxies "most recent login" if ever needed.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

// Mirrors packages/contracts `visibilitySchema` (PRD §8.1).
enum Visibility {
  private
  unlisted
  public
}

// Mirrors packages/contracts `coinImageTypeSchema` (PRD §11.4). No `primary` —
// the primary image is a designation via Coin.primaryImageId (§11.3, §11.5).
enum CoinImageType {
  obverse
  reverse
  edge
  detail
  slab
  other
}

// Mirrors packages/contracts `datePrecisionSchema` (PRD §36.2).
enum DatePrecision {
  exact
  circa
  range
  unknown
}

// §11.11 / §12.12: shared by ContentReport.targetType and SlugRedirect.contentType.
enum ContentKind {
  profile
  coin
  collection
}

// §11.11
enum ReportStatus {
  new
  reviewing
  resolved
  dismissed
}

// ---------------------------------------------------------------------------
// User & auth (§11.1, §36.1) — Better Auth's canonical shape (User, Session,
// Account, Verification). See file header for the reconciliation notes.
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified Boolean   @default(false)

  name  String
  image String?

  username      String  @unique
  bio           String?
  broadLocation String?
  publicProfileEnabled Boolean @default(true)

  // §36.4: soft-delete grace window before hard purge.
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions Session[]
  accounts Account[]

  coins          Coin[]
  collections    Collection[]
  contentReports ContentReport[]
  slugRedirects  SlugRedirect[]

  @@index([deletedAt])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// One row per linked auth method (email+password credential, Google OAuth,
// future providers) — a User may have several. Password hash lives here
// (Account.password), on the "credential" provider's row, not on User.
model Account {
  id         String @id @default(cuid())
  accountId  String
  providerId String

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// Generic token store Better Auth manages itself: email verification,
// password reset, and similar single-use tokens.
model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([identifier])
}

// ---------------------------------------------------------------------------
// Coin (§11.2, §36.2)
// ---------------------------------------------------------------------------

model Coin {
  id      String @id @default(cuid())
  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  title String
  slug  String

  primaryImageId String?     @unique
  primaryImage   CoinImage?  @relation("CoinPrimaryImage", fields: [primaryImageId], references: [id], onDelete: SetNull)

  countryRegion String?
  rulerIssuer   String?

  // §36.2 year/date model.
  dateDisplay   String?
  yearStart     Int?
  yearEnd       Int?
  datePrecision DatePrecision @default(unknown)

  denomination String?
  mint         String?
  material     String?
  weight       String?
  diameter     String?
  grade        String?
  gradingService      String?
  certificationNumber String?
  varietySubtype      String?

  description String?

  visibility     Visibility @default(private)
  unlistedToken  String?    @unique

  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images             CoinImage[] @relation("CoinImages")
  catalogReferences  CatalogReference[]
  provenance         Provenance?
  tags               CoinTag[]
  collectionEntries  CollectionCoin[]

  @@unique([ownerId, slug])
  @@index([ownerId])
  @@index([visibility])
  @@index([deletedAt])
  @@index([yearStart, yearEnd])
}

// ---------------------------------------------------------------------------
// Coin Image (§11.3–11.5)
// ---------------------------------------------------------------------------

model CoinImage {
  id     String @id @default(cuid())
  coinId String
  coin   Coin   @relation("CoinImages", fields: [coinId], references: [id], onDelete: Cascade)

  imageUrl         String
  thumbnailUrl     String
  originalImageUrl String?

  type     CoinImageType
  altText  String?
  sortOrder Int

  width    Int?
  height   Int?
  fileSize Int?
  mimeType String?

  createdAt DateTime @default(now())

  // Inverse side of Coin.primaryImageId (§11.5 primary image designation).
  primaryForCoin Coin? @relation("CoinPrimaryImage")

  @@index([coinId, sortOrder])
}

// ---------------------------------------------------------------------------
// Catalog Reference (§11.6)
// ---------------------------------------------------------------------------

model CatalogReference {
  id     String @id @default(cuid())
  coinId String
  coin   Coin   @relation(fields: [coinId], references: [id], onDelete: Cascade)

  system String
  number String
  notes  String?

  @@index([coinId])
}

// ---------------------------------------------------------------------------
// Provenance (§11.7) — private by default, one record per coin.
// ---------------------------------------------------------------------------

model Provenance {
  id     String @id @default(cuid())
  coinId String @unique
  coin   Coin   @relation(fields: [coinId], references: [id], onDelete: Cascade)

  acquisitionDate   DateTime?
  acquisitionSource String?
  acquisitionPrice  Decimal? @db.Decimal(12, 2)
  previousOwner     String?
  notes             String?
}

// ---------------------------------------------------------------------------
// Collection (§11.8–11.10)
// ---------------------------------------------------------------------------

model Collection {
  id      String @id @default(cuid())
  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  title       String
  slug        String
  description String?

  coverImageId String?

  visibility    Visibility @default(private)
  unlistedToken String?    @unique

  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  coins CollectionCoin[]
  tags  CollectionTag[]

  @@unique([ownerId, slug])
  @@index([ownerId])
  @@index([visibility])
  @@index([deletedAt])
}

// §11.9: ordered membership, manual sort order with added-date fallback (§11.10).
model CollectionCoin {
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  coinId       String
  coin         Coin       @relation(fields: [coinId], references: [id], onDelete: Cascade)

  sortOrder Int
  addedAt   DateTime @default(now())

  @@id([collectionId, coinId])
  @@index([coinId])
  @@index([collectionId, sortOrder])
}

// ---------------------------------------------------------------------------
// Tags (§17.2 search, §17.1 popular tags) — normalized for counting/filtering.
// ---------------------------------------------------------------------------

model Tag {
  id   String @id @default(cuid())
  name String @unique

  coins       CoinTag[]
  collections CollectionTag[]
}

model CoinTag {
  coinId String
  coin   Coin   @relation(fields: [coinId], references: [id], onDelete: Cascade)
  tagId  String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([coinId, tagId])
  @@index([tagId])
}

model CollectionTag {
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  tagId        String
  tag          Tag        @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([collectionId, tagId])
  @@index([tagId])
}

// ---------------------------------------------------------------------------
// Content Report (§11.11, §23)
// ---------------------------------------------------------------------------

model ContentReport {
  id String @id @default(cuid())

  targetType ContentKind
  targetId   String

  reporterUserId String?
  reporterUser   User?   @relation(fields: [reporterUserId], references: [id], onDelete: SetNull)
  reporterEmail  String?

  reason  String
  details String?
  status  ReportStatus @default(new)

  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([targetType, targetId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Slug Redirect (§11.12, §12.4, §12.6)
// ---------------------------------------------------------------------------

model SlugRedirect {
  id String @id @default(cuid())

  ownerId String?
  owner   User?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  contentType ContentKind
  contentId   String

  oldPath String @unique
  newPath String

  createdAt DateTime @default(now())

  @@index([contentType, contentId])
}
