# Copy to .env and fill in. Never commit real secrets (.env is gitignored).

# --- Database (Railway Postgres) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# --- Better Auth ---
# Generate a strong secret, e.g. `openssl rand -base64 32`
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# --- Google OAuth (optional; verified-by-provider, skips the email-verification gate) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Cloudflare R2 (S3-compatible object storage) ---
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_BASE_URL=""

# --- Image service (sharp worker) ---
IMAGE_SERVICE_URL="http://localhost:4000"
