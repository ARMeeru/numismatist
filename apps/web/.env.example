# Copy to .env in this directory. Next.js loads plain .env files automatically;
# so does this app's vitest setup (for tests that hit the database via @numismatist/db).
DATABASE_URL="postgresql://numismatist:numismatist_dev@localhost:5432/numismatist_dev"

# --- Better Auth ---
# Read automatically from env by Better Auth (not passed explicitly in auth.ts).
# Generate a strong secret, e.g. `openssl rand -base64 32`
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# --- Google OAuth (optional; verified-by-provider, skips the email-verification gate) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
